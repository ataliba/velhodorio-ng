[Unit]
Description=Velho do Rio - Consumidor SQS (WhatsApp/Telegram)
After=network.target

[Service]
Type=simple
User=YOUR_USER
WorkingDirectory=/home/YOUR_USER/velhodorio-ng
ExecStart=/usr/bin/infisical run -- /home/YOUR_USER/velhodorio-ng/venv/bin/python /home/YOUR_USER/velhodorio-ng/velhodorio.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
